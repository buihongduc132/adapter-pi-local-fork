{
  "name": "@buihongduc132/adapter-pi-local-fork",
  "version": "0.4.0",
  "description": "Fork of @paperclipai/adapter-pi-local with opt-in model preflight",
  "license": "MIT",
  "homepage": "https://github.com/buihongduc132/adapter-pi-local-fork",
  "bugs": {
    "url": "https://github.com/buihongduc132/adapter-pi-local-fork/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/buihongduc132/adapter-pi-local-fork"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./ui": "./src/ui/index.ts",
    "./cli": "./src/cli/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server/index.d.ts",
        "import": "./dist/server/index.js"
      },
      "./ui": {
        "types": "./dist/ui/index.d.ts",
        "import": "./dist/ui/index.js"
      },
      "./cli": {
        "types": "./dist/cli/index.d.ts",
        "import": "./dist/cli/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest/index.js",
    "worker": "./dist/worker/index.js"
  },
  "keywords": [
    "paperclip",
    "adapter",
    "pi",
    "plugin"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "2026.517.0",
    "@paperclipai/plugin-sdk": "2026.517.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  }
}
