{
  "name": "adapter-pi-local",
  "version": "0.4.0",
  "description": "Fork of @paperclipai/adapter-pi-local with opt-in model preflight",
  "license": "MIT",
  "homepage": "https://github.com/buihongduc132/adapter-pi-local",
  "bugs": {
    "url": "https://github.com/buihongduc132/adapter-pi-local/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/buihongduc132/adapter-pi-local"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist"
  ],

  "keywords": [
    "paperclip",
    "adapter",
    "pi",
    "plugin"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "2026.517.0",
    "@paperclipai/plugin-sdk": "2026.517.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  }
}
